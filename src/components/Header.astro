---
import navData from "../data/nav.json";

interface NavLink {
  label: string;
  href: string;
  badge?: string;
  highlight?: boolean;
  external?: boolean;
}

interface NavGroup {
  heading: string;
  links: NavLink[];
}

interface NavItem {
  label: string;
  href: string;
  groups?: NavGroup[];
  featured?: {
    image: string;
    title: string;
    href: string;
  };
}

interface UtilityLink {
  label: string;
  href: string;
  external?: boolean;
}

const utility: UtilityLink[] = (navData as any).utility;
const audiences: NavItem[] = (navData as any).audiences;
const main: NavItem[] = (navData as any).main;
---

<header class="site-header">
  <!-- Tier 1: Utility bar -->
  <div class="site-header__utility">
    <div class="container site-header__utility-inner">
      {utility.filter((link) => link.label !== "Open a Fund").map((link) => (
        <a
          href={link.href}
          {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
          {link.label}
          <svg class="utility-external-icon" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 3L3 9M9 3H5M9 3v4" />
          </svg>
        </a>
      ))}
    </div>
  </div>

  <!-- Tier 2: Audience bar (green) -->
  <div class="audience-bar">
    <div class="container audience-bar__inner">
      <span class="audience-bar__label">I'm a:</span>
      {audiences.map((item, index) => (
        <button
          class="audience-bar__link"
          aria-expanded="false"
          aria-controls={`audience-panel-${index}`}
          data-mega-trigger
        >
          {item.label}
          <svg class="audience-bar__chevron" width="10" height="10" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      ))}
    </div>
  </div>

  <!-- Main header bar -->
  <div class="site-header__main">
    <div class="container site-header__inner">
      <!-- Logo -->
      <div class="site-header__logo">
        <a href="/">
          <img src="/thcf-logo.svg" alt="Truman Heartland Community Foundation" class="site-header__logo-img" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="site-nav__list">
          {main.map((item, index) => (
            <li class="site-nav__item">
              {item.groups && item.groups.length > 0 ? (
                <button
                  class="site-nav__link"
                  aria-expanded="false"
                  aria-controls={`mega-panel-${index}`}
                  data-mega-trigger
                >
                  {item.label}
                  <svg class="site-nav__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              ) : (
                <a href={item.href} class="site-nav__link">{item.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <!-- Search + Desktop actions -->
      <div class="site-header__actions">
        <a href="/search" class="site-nav__search" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </a>
        <a href="/donors/make-a-gift" class="btn btn-primary btn-sm">Open a Fund</a>
      </div>

      <!-- Mobile menu toggle -->
      <button
        class="mobile-menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Toggle navigation menu"
      >
        <span></span>
      </button>
    </div>
  </div>

  <!-- Audience Mega Panels -->
  {audiences.map((item, index) => (
    item.groups && item.groups.length > 0 && (
      <div
        id={`audience-panel-${index}`}
        class="mega-panel"
        aria-hidden="true"
        data-mega-panel
      >
        <div class="container">
          <div class="mega-panel__grid--grouped no-featured">
            {item.groups.map((group) => (
              <div class="mega-panel__group">
                <h4 class="mega-panel__group-heading">{group.heading}</h4>
                <div class="mega-panel__group-links">
                  {group.links.map((link) => (
                    <a
                      href={link.href}
                      class:list={[
                        'mega-panel__group-link',
                        link.highlight && 'mega-panel__group-link--highlight',
                        link.external && 'mega-panel__group-link--external',
                      ]}
                      {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                    >
                      {link.label}
                      {link.badge && <span class="mega-panel__badge">{link.badge}</span>}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
          <div style="margin-top: var(--space-lg); padding-top: var(--space-md); border-top: 1px solid var(--color-gray-200);">
            <a href={item.href} style="color: var(--color-green); font-weight: 600; font-size: var(--text-sm); text-decoration: none;">
              View all {item.label.replace('For ', '').toLowerCase()} resources &rarr;
            </a>
          </div>
        </div>
      </div>
    )
  ))}

  <!-- Main Nav Mega Panels -->
  {main.map((item, index) => (
    item.groups && item.groups.length > 0 && (
      <div
        id={`mega-panel-${index}`}
        class="mega-panel"
        aria-hidden="true"
        data-mega-panel
      >
        <div class="container">
          <div class:list={['mega-panel__grid--grouped', !item.featured && 'no-featured']}>
            {item.groups.map((group) => (
              <div class="mega-panel__group">
                <h4 class="mega-panel__group-heading">{group.heading}</h4>
                <div class="mega-panel__group-links">
                  {group.links.map((link) => (
                    <a
                      href={link.href}
                      class:list={[
                        'mega-panel__group-link',
                        link.highlight && 'mega-panel__group-link--highlight',
                        link.external && 'mega-panel__group-link--external',
                      ]}
                      {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                    >
                      {link.label}
                      {link.badge && <span class="mega-panel__badge">{link.badge}</span>}
                    </a>
                  ))}
                </div>
              </div>
            ))}

            {item.featured && (
              <a href={item.featured.href} class="mega-panel__featured" style="text-decoration: none;">
                <div class="mega-panel__featured-image">
                  <img src={item.featured.image} alt="" loading="lazy" />
                </div>
                <p class="mega-panel__featured-title">{item.featured.title}</p>
                <span class="mega-panel__featured-link">Read more &rarr;</span>
              </a>
            )}
          </div>
        </div>
      </div>
    )
  ))}

  <!-- Mobile Navigation -->
  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation">
    <!-- Audience cards first -->
    <div class="mobile-nav__audiences">
      {audiences.map((item) => (
        <a href={item.href} class="mobile-nav__audience-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          {item.label}
        </a>
      ))}
    </div>

    <!-- Main nav items -->
    <ul class="mobile-nav__list">
      {main.map((item, index) => (
        <li class="mobile-nav__item">
          <div style="display: flex; align-items: center;">
            <a href={item.href} class="mobile-nav__link" style="flex: 1;">
              {item.label}
            </a>
            {item.groups && item.groups.length > 0 && (
              <button
                class="mobile-nav__toggle"
                aria-expanded="false"
                aria-controls={`mobile-dropdown-${index}`}
                aria-label={`Toggle ${item.label} submenu`}
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            )}
          </div>
          {item.groups && item.groups.length > 0 && (
            <div id={`mobile-dropdown-${index}`} class="mobile-nav__dropdown">
              {item.groups.map((group) => (
                <div style="margin-bottom: var(--space-sm);">
                  <span style="display: block; padding: 0.375rem 0 0.375rem var(--space-lg); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-green); font-weight: 700;">
                    {group.heading}
                  </span>
                  {group.links.map((link) => (
                    <a
                      href={link.href}
                      {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                    >
                      {link.label}
                      {link.badge && <span style="margin-left: var(--space-xs); font-size: 0.625rem; background: var(--color-green); color: white; padding: 0.125rem 0.375rem; border-radius: 2px; text-transform: uppercase; font-weight: 700;">{link.badge}</span>}
                    </a>
                  ))}
                </div>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
    <div class="mobile-nav__actions">
      <a href="/donors/make-a-gift" class="btn btn-primary">Open a Fund</a>
      <a href="https://thcf.fcsuite.com/erp/portal" target="_blank" rel="noopener noreferrer">
        Fund Portal
      </a>
    </div>
  </nav>
</header>

<script>
  // ----- Desktop Mega Menu -----
  const triggers = document.querySelectorAll('[data-mega-trigger]');
  const panels = document.querySelectorAll('[data-mega-panel]');
  let activePanel: Element | null = null;

  function closeAllPanels() {
    triggers.forEach((t) => t.setAttribute('aria-expanded', 'false'));
    panels.forEach((p) => {
      p.classList.remove('is-open');
      p.setAttribute('aria-hidden', 'true');
    });
    activePanel = null;
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const panelId = trigger.getAttribute('aria-controls');
      if (!panelId) return;
      const panel = document.getElementById(panelId);
      if (!panel) return;

      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close everything first
      closeAllPanels();

      // If it was closed, open this one
      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        panel.classList.add('is-open');
        panel.setAttribute('aria-hidden', 'false');
        activePanel = panel;
      }
    });
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (activePanel && !(e.target as Element)?.closest('.site-header')) {
      closeAllPanels();
    }
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (activePanel) {
        closeAllPanels();
      }
      // Also close mobile menu
      const mobileNav = document.getElementById('mobile-nav');
      const menuToggle = document.querySelector('.mobile-menu-toggle');
      if (mobileNav?.classList.contains('is-open')) {
        menuToggle?.setAttribute('aria-expanded', 'false');
        mobileNav.classList.remove('is-open');
        document.body.style.overflow = '';
      }
    }
  });

  // ----- Mobile Menu -----
  const menuToggle = document.querySelector('.mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  if (menuToggle && mobileNav) {
    menuToggle.addEventListener('click', () => {
      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!isOpen));
      mobileNav.classList.toggle('is-open');
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });
  }

  // Mobile dropdown toggles
  const dropdownToggles = document.querySelectorAll('.mobile-nav__toggle');
  dropdownToggles.forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      const targetId = toggle.getAttribute('aria-controls');
      if (targetId) {
        const dropdown = document.getElementById(targetId);
        if (dropdown) {
          dropdown.classList.toggle('is-open');
        }
      }
    });
  });
</script>
