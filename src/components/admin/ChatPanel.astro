---
// Chatbot panel for the editor. Renders an empty conversation with
// context-aware suggested prompts. All interaction happens in the browser
// via the inline <script>: it talks to /api/chat and /api/pages/.../apply-proposal.

interface SuggestedPrompt {
  label: string;
  prompt: string;
}

interface Props {
  slug: string;
  pageKey: string; // URL key (slug or __home__) for building fetch URLs
  template: string;
  title: string;
  sectionCount: number;
  suggestedPrompts: SuggestedPrompt[];
}

const { slug, pageKey, template, title, sectionCount, suggestedPrompts } = Astro.props;
---

<section class="chat-panel editor-card" data-slug={slug} data-page-key={pageKey}>
  <h2>Content assistant</h2>
  <p class="hint">
    Ask for edits in plain language. Small changes apply immediately. Big changes (like switching templates) are proposed first and wait for your confirmation.
  </p>

  <div class="chat-feed" id="chat-feed" aria-live="polite">
    <div class="chat-empty">
      <p class="chat-empty__hello">
        Hi! I can edit <strong>{title}</strong> ({template} template, {sectionCount} sections) for you.
      </p>
      <p class="chat-empty__try">Try one of these:</p>
      <div class="chat-suggestions">
        {suggestedPrompts.map((s) => (
          <button type="button" class="chat-suggest" data-prompt={s.prompt}>
            {s.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <form class="chat-form" id="chat-form">
    <textarea
      id="chat-input"
      name="message"
      placeholder="Ask me to edit this page..."
      rows="2"
      required
    ></textarea>
    <button type="submit" class="admin-btn" id="chat-send">Send</button>
  </form>

  <template id="chat-msg-user">
    <div class="chat-msg chat-msg--user">
      <div class="chat-msg__bubble"></div>
    </div>
  </template>
  <template id="chat-msg-assistant">
    <div class="chat-msg chat-msg--assistant">
      <div class="chat-msg__bubble">
        <div class="chat-msg__text"></div>
        <ul class="chat-msg__activity"></ul>
        <div class="chat-msg__actions"></div>
      </div>
    </div>
  </template>

  <style>
    .chat-panel {
      display: flex;
      flex-direction: column;
    }
    .chat-feed {
      display: flex;
      flex-direction: column;
      gap: .75rem;
      max-height: 480px;
      overflow-y: auto;
      padding: .25rem .25rem .75rem;
      margin: 0 -.25rem .75rem;
    }
    .chat-empty { color: var(--text-dim); }
    .chat-empty__hello { margin: 0 0 .75rem; }
    .chat-empty__try { margin: 0 0 .5rem; font-size: .8rem; text-transform: uppercase; letter-spacing: .08em; color: var(--text-muted); }
    .chat-suggestions { display: flex; flex-direction: column; gap: .4rem; }
    .chat-suggest {
      text-align: left;
      padding: .55rem .75rem;
      background: var(--panel-2);
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 6px;
      cursor: pointer;
      font-size: .85rem;
      transition: border-color .15s;
    }
    .chat-suggest:hover { border-color: var(--accent); color: var(--accent); }
    .chat-msg { display: flex; }
    .chat-msg--user { justify-content: flex-end; }
    .chat-msg__bubble {
      max-width: 85%;
      padding: .65rem .9rem;
      border-radius: 12px;
      font-size: .9rem;
      line-height: 1.5;
      white-space: pre-wrap;
    }
    .chat-msg--user .chat-msg__bubble {
      background: var(--accent);
      color: white;
      border-bottom-right-radius: 4px;
    }
    .chat-msg--assistant .chat-msg__bubble {
      background: var(--panel-2);
      border: 1px solid var(--border);
      color: var(--text);
      border-bottom-left-radius: 4px;
    }
    .chat-msg__activity {
      list-style: none;
      padding: 0;
      margin: .6rem 0 0;
      font-size: .8rem;
      display: flex;
      flex-direction: column;
      gap: .25rem;
    }
    .chat-msg__activity:empty { display: none; }
    .chat-msg__activity li {
      color: var(--text-dim);
      padding-left: 1.25rem;
      position: relative;
    }
    .chat-msg__activity li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--success);
    }
    .chat-msg__activity li.status-error::before { content: '✕'; color: var(--danger); }
    .chat-msg__activity li.status-proposed::before { content: '◦'; color: #e6a700; }
    .chat-msg__actions {
      display: flex;
      gap: .4rem;
      margin-top: .6rem;
      flex-wrap: wrap;
    }
    .chat-msg__actions:empty { display: none; }
    .chat-msg__actions button {
      font-size: .8rem;
      padding: .35rem .7rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-dim);
      cursor: pointer;
    }
    .chat-msg__actions button.apply { background: var(--accent); color: white; border-color: var(--accent); }
    .chat-msg__actions button.apply:hover { background: var(--accent-hover); }
    .chat-msg__actions button.danger { color: var(--danger); border-color: var(--danger); }
    .chat-msg__actions button:hover { color: var(--text); }
    .chat-form {
      display: flex;
      gap: .5rem;
      align-items: flex-end;
    }
    .chat-form textarea {
      flex: 1;
      background: var(--panel-2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: .55rem .7rem;
      border-radius: 6px;
      font-size: .9rem;
      font-family: inherit;
      resize: vertical;
      box-sizing: border-box;
    }
    .chat-form button { white-space: nowrap; }
    .chat-form button[disabled] { opacity: 0.5; cursor: wait; }
  </style>

  <script is:inline define:vars={{ pageKey }}>
    (() => {
      const panel = document.querySelector('.chat-panel');
      if (!panel) return;
      const slug = panel.dataset.slug ?? '';
      const feed = panel.querySelector('#chat-feed');
      const empty = feed.querySelector('.chat-empty');
      const form = panel.querySelector('#chat-form');
      const input = panel.querySelector('#chat-input');
      const sendBtn = panel.querySelector('#chat-send');
      const userTpl = panel.querySelector('#chat-msg-user');
      const asstTpl = panel.querySelector('#chat-msg-assistant');
      const preview = document.getElementById('preview');

      // Conversation lives in memory for this tab.
      /** @type {Array<{role:string,content:any}>} */
      const history = [];

      const slugPath = slug.split('/').map(encodeURIComponent).join('/');

      function appendUser(text) {
        if (empty) empty.remove();
        const node = userTpl.content.cloneNode(true);
        node.querySelector('.chat-msg__bubble').textContent = text;
        feed.appendChild(node);
        feed.scrollTop = feed.scrollHeight;
      }

      function appendAssistant({ text, activity, proposals, toolUseIdsInTurn }) {
        if (empty && feed.contains(empty)) empty.remove();
        const node = asstTpl.content.cloneNode(true);
        const bubble = node.querySelector('.chat-msg__bubble');
        const textEl = node.querySelector('.chat-msg__text');
        const activityEl = node.querySelector('.chat-msg__activity');
        const actionsEl = node.querySelector('.chat-msg__actions');

        textEl.textContent = text || (activity.length > 0 || proposals.length > 0 ? '' : '(no reply)');
        if (!textEl.textContent) textEl.remove();

        for (const a of activity) {
          const li = document.createElement('li');
          li.className = 'status-' + a.status;
          li.textContent = a.detail ? a.label + ' — ' + a.detail : a.label;
          activityEl.appendChild(li);
        }

        // For each proposal, render Apply / Cancel buttons.
        for (const p of proposals) {
          const proposalId = 'proposal-' + Math.random().toString(36).slice(2, 8);
          const wrap = document.createElement('div');
          wrap.className = 'proposal-group';
          wrap.dataset.proposalId = proposalId;
          const summary = document.createElement('p');
          summary.style.margin = '.5rem 0';
          summary.style.fontSize = '.85rem';
          summary.textContent = p.summary;
          actionsEl.before(summary);

          const apply = document.createElement('button');
          apply.type = 'button';
          apply.className = 'apply';
          apply.textContent = 'Apply';
          apply.onclick = async () => {
            apply.disabled = true;
            apply.textContent = 'Applying…';
            const res = await fetch('/api/pages/' + slugPath + '/apply-proposal', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ proposal: p }),
            });
            const payload = await res.json().catch(() => ({}));
            if (!res.ok) {
              apply.textContent = 'Apply';
              apply.disabled = false;
              alert('Apply failed: ' + (payload.error ?? res.status));
              return;
            }
            summary.textContent += '  · applied.';
            apply.remove();
            cancel.textContent = 'Undo';
            cancel.className = 'danger';
            cancel.disabled = false;
            reloadPreview();
          };
          const cancel = document.createElement('button');
          cancel.type = 'button';
          cancel.textContent = 'Cancel';
          cancel.onclick = () => { wrap.remove(); apply.remove(); cancel.remove(); summary.textContent += '  · cancelled.'; };
          actionsEl.append(apply, cancel);
        }

        // "Undo" button for bot-authored edits (any activity with status ok).
        const hasCommittedWrite = activity.some((a) =>
          a.status === 'ok' && !['get_page','list_pages','list_templates'].includes(a.label)
        );
        if (hasCommittedWrite) {
          const undo = document.createElement('button');
          undo.type = 'button';
          undo.className = 'danger';
          undo.textContent = 'Undo this';
          undo.onclick = async () => {
            undo.disabled = true;
            undo.textContent = 'Undoing…';
            const vres = await fetch('/api/pages/' + slugPath + '/versions');
            const { versions } = await vres.json();
            // Find the most recent version BEFORE this turn's writes. That's
            // the one we want to revert to.
            const beforeTurn = versions.find((v) => v.author !== 'bot' || !toolUseIdsInTurn.includes(v.chatTurn?.toolCalls?.[0]?.name ?? ''));
            // Simpler heuristic: pick versions[0] if it was created by the
            // bot during this turn, else pick versions[1]. This relies on
            // versions being ordered newest-first.
            const target = versions[0];
            if (!target) { undo.textContent = 'Undo this'; undo.disabled = false; alert('No version to revert to'); return; }
            const rres = await fetch('/api/pages/' + slugPath + '/revert', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ versionId: target.id }),
            });
            if (!rres.ok) {
              const payload = await rres.json().catch(() => ({}));
              undo.textContent = 'Undo this';
              undo.disabled = false;
              alert('Undo failed: ' + (payload.error ?? rres.status));
              return;
            }
            undo.textContent = 'Undone';
            reloadPreview();
          };
          actionsEl.appendChild(undo);
        }

        feed.appendChild(node);
        feed.scrollTop = feed.scrollHeight;
      }

      function reloadPreview() {
        if (!preview) return;
        const url = new URL(preview.src);
        url.searchParams.set('v', String(Date.now()));
        preview.src = url.toString();
      }

      async function send(text) {
        appendUser(text);
        history.push({ role: 'user', content: text });
        sendBtn.disabled = true;
        input.disabled = true;
        sendBtn.textContent = 'Thinking…';

        try {
          const res = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ slug, messages: history }),
          });
          const payload = await res.json();
          if (!res.ok) {
            appendAssistant({ text: 'Error: ' + (payload.error ?? res.status), activity: [], proposals: [], toolUseIdsInTurn: [] });
            return;
          }
          // Append returned assistant/tool messages back into the history.
          for (const m of payload.messages) history.push(m);

          // For UI purposes, extract the final assistant text block.
          const finalAssistant = [...payload.messages].reverse().find((m) => m.role === 'assistant');
          const finalText = finalAssistant && Array.isArray(finalAssistant.content)
            ? finalAssistant.content.filter((b) => b.type === 'text').map((b) => b.text).join('\n')
            : '';

          const toolUseIds = payload.activity.map((a) => a.toolUseId);
          appendAssistant({
            text: finalText,
            activity: payload.activity,
            proposals: payload.proposals,
            toolUseIdsInTurn: toolUseIds,
          });

          // If the bot made committed writes this turn, refresh the preview so
          // the editor sees the change immediately.
          if (payload.activity.some((a) => a.status === 'ok' &&
              !['get_page','list_pages','list_templates'].includes(a.label))) {
            reloadPreview();
          }
        } catch (err) {
          appendAssistant({ text: 'Network error: ' + (err && err.message ? err.message : String(err)), activity: [], proposals: [], toolUseIdsInTurn: [] });
        } finally {
          sendBtn.disabled = false;
          input.disabled = false;
          sendBtn.textContent = 'Send';
          input.value = '';
          input.focus();
        }
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const text = input.value.trim();
        if (!text) return;
        void send(text);
      });

      // Clicking a suggestion fills the input and sends.
      panel.querySelectorAll('.chat-suggest').forEach((btn) => {
        btn.addEventListener('click', () => {
          input.value = btn.dataset.prompt ?? '';
          void send(input.value);
        });
      });

      // Cmd/Ctrl+Enter submits.
      input.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
          e.preventDefault();
          form.requestSubmit();
        }
      });
    })();
  </script>
</section>
