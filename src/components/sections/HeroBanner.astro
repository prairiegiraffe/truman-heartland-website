---
interface Image {
  src: string;
  alt?: string;
}

interface Cta {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'outline-white' | 'ghost';
}

interface Props {
  backgroundImage?: Image;
  overlayColor?: 'none' | 'dark' | 'navy' | 'green';
  minHeight?: 'short' | 'medium' | 'tall';
  eyebrow?: string;
  title: string;
  subtitle?: string;
  buttons?: Cta[];
  alignment?: 'left' | 'center';
  parallax?: boolean;
}

const {
  backgroundImage,
  overlayColor = 'dark',
  minHeight = 'tall',
  eyebrow,
  title,
  subtitle,
  buttons = [],
  alignment = 'center',
  parallax = false,
} = Astro.props;
---

<section
  class={`hero-banner hero-banner--${minHeight} hero-banner--align-${alignment} ${parallax ? 'hero-banner--parallax' : ''}`}
>
  {backgroundImage?.src && (
    <img
      class="hero-banner__bg"
      src={backgroundImage.src}
      alt={backgroundImage.alt ?? ''}
      loading="eager"
    />
  )}
  {overlayColor !== 'none' && <div class={`hero-banner__overlay hero-banner__overlay--${overlayColor}`} />}
  <div class="container hero-banner__content">
    {eyebrow && <p class="hero-banner__eyebrow reveal">{eyebrow}</p>}
    <h1 class="hero-banner__title reveal">{title}</h1>
    {subtitle && <p class="hero-banner__subtitle reveal">{subtitle}</p>}
    {buttons.length > 0 && (
      <div class="hero-banner__actions reveal">
        {buttons.map((b) => (
          <a href={b.href} class={`btn btn-${b.variant ?? 'primary'} btn-lg`}>{b.label}</a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
    color: white;
    text-align: center;
  }
  .hero-banner--align-left { text-align: left; }
  .hero-banner--align-left .container { display: block; }
  .hero-banner--short { min-height: 40vh; padding: var(--space-2xl) 0; }
  .hero-banner--medium { min-height: 55vh; padding: var(--space-3xl) 0; }
  .hero-banner--tall { min-height: 70vh; padding: var(--space-3xl) 0; }
  .hero-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }
  @media (min-width: 768px) {
    .hero-banner--parallax .hero-banner__bg {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
    }
  }
  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero-banner__overlay--dark { background: linear-gradient(135deg, rgba(0,31,63,0.92) 0%, rgba(0,31,63,0.7) 100%); }
  .hero-banner__overlay--navy { background: rgba(0,31,63,0.85); }
  .hero-banner__overlay--green { background: rgba(30,132,73,0.85); }
  .hero-banner__content {
    position: relative;
    max-width: 820px;
  }
  .hero-banner--align-left .hero-banner__content { margin-left: var(--container-padding); max-width: 720px; }
  .hero-banner__eyebrow {
    color: var(--color-green);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: var(--text-sm);
    margin: 0 0 var(--space-sm);
  }
  .hero-banner__title {
    margin: 0 0 var(--space-md);
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    line-height: 1.1;
    color: white;
  }
  .hero-banner__subtitle {
    margin: 0 auto var(--space-lg);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    opacity: 0.92;
    max-width: 680px;
  }
  .hero-banner--align-left .hero-banner__subtitle { margin-left: 0; }
  .hero-banner__actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-banner--align-left .hero-banner__actions { justify-content: flex-start; }
</style>
