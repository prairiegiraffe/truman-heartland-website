---
import SectionHeader from '../SectionHeader.astro';
import { bgClass, type BgTone } from './bg';

interface Avatar {
  src: string;
  alt?: string;
}

interface Item {
  quote: string;
  author: string;
  meta?: string;
  avatar?: Avatar;
}

interface Props {
  eyebrow?: string;
  title?: string;
  bg?: BgTone;
  items: Item[];
}

const { eyebrow, title, bg = 'light', items } = Astro.props;

function initials(name: string): string {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase() ?? '')
    .join('');
}
---

<section class={`section ${bgClass(bg)}`}>
  <div class="container">
    {title && <SectionHeader eyebrow={eyebrow} title={title} accent={true} />}
    <div class="testimonial-grid">
      {items.map((it) => (
        <figure class="testimonial-card">
          <blockquote class="testimonial-card__quote">
            <p>{it.quote}</p>
          </blockquote>
          <figcaption class="testimonial-card__foot">
            {it.avatar?.src ? (
              <img class="testimonial-card__avatar-img" src={it.avatar.src} alt={it.avatar.alt ?? it.author} loading="lazy" />
            ) : (
              <span class="testimonial-card__avatar" aria-hidden="true">{initials(it.author)}</span>
            )}
            <div class="testimonial-card__author">
              <strong>{it.author}</strong>
              {it.meta && <span>{it.meta}</span>}
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .testimonial-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .testimonial-card {
    background: white;
    padding: var(--space-xl);
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    margin: 0;
  }
  .testimonial-card__quote {
    margin: 0 0 var(--space-md);
    border: none;
    padding: 0;
    color: var(--color-navy);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }
  .testimonial-card__quote p::before { content: '“'; }
  .testimonial-card__quote p::after { content: '”'; }
  .testimonial-card__foot {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }
  .testimonial-card__avatar,
  .testimonial-card__avatar-img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-green);
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
    object-fit: cover;
  }
  .testimonial-card__author { display: flex; flex-direction: column; line-height: 1.3; }
  .testimonial-card__author strong { color: var(--color-navy); }
  .testimonial-card__author span { color: var(--color-text-light); font-size: var(--text-sm); }
</style>
