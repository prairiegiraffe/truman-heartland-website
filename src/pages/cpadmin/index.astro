---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDB, listPages } from '../../lib/d1';

export const prerender = false;

const db = getDB(Astro.locals);
const search = Astro.url.searchParams.get('q')?.trim() ?? '';
const pages = await listPages(db, search || undefined);

function fmtDate(ms: number): string {
  const d = new Date(ms);
  return d.toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
}
---
<AdminLayout title="Pages">
  <header class="admin-header">
    <div>
      <h1>Pages</h1>
      <p class="admin-sub">{pages.length} page{pages.length === 1 ? '' : 's'} in D1</p>
    </div>
    <form method="get" class="admin-search">
      <input name="q" type="search" placeholder="Search title or path" value={search} />
      <button type="submit">Search</button>
    </form>
  </header>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Path</th>
        <th>Template</th>
        <th>Type</th>
        <th>Updated</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {pages.map((p) => (
        <tr>
          <td class="admin-title-cell">{p.title}</td>
          <td><code>{p.path}</code></td>
          <td><span class="chip">{p.template}</span></td>
          <td><span class="chip chip--muted">{p.type}</span></td>
          <td class="admin-dim">{fmtDate(p.updatedAt)}</td>
          <td><a class="admin-btn" href={`/cpadmin/pages/${p.slug || '__home__'}`}>Edit</a></td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
