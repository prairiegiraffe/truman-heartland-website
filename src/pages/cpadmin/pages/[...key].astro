---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ChatPanel from '../../../components/admin/ChatPanel.astro';
import { getDB, getPage, listVersions } from '../../../lib/d1';
import { TEMPLATES, UNIVERSAL_SECTIONS, getTemplate } from '../../../lib/templates';
import { SECTION_KINDS } from '../../../lib/sections';

export const prerender = false;

const key = Astro.params.key ?? '';
const slug = key === '__home__' ? '' : key;

const db = getDB(Astro.locals);
const page = await getPage(db, slug);
if (!page) {
  return new Response('page not found', { status: 404 });
}
const versions = await listVersions(db, slug, 20);
const template = getTemplate(page.template);
const preferredKinds = template ? template.preferredSections : [];
const otherKinds = SECTION_KINDS.filter(
  (k) => !preferredKinds.includes(k) && !UNIVERSAL_SECTIONS.includes(k)
);
const sectionCount = Array.isArray(page.sections) ? page.sections.length : 0;

function fmtDate(ms: number): string {
  return new Date(ms).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
}

// Context-aware empty-state prompts for the chat panel.
function suggestedPrompts() {
  const templateId = page.template;
  const common = [
    { label: 'Rewrite the page title to be more compelling', prompt: 'Rewrite the page title to be more compelling and clear.' },
    { label: 'Add a CTA band at the bottom', prompt: 'Add a cta-band section at the end of the page with a headline that matches this page\'s topic and a button to /about/contact-us.' },
  ];
  if (templateId === 'legacy') {
    return [
      { label: 'Convert this page to the pillar template', prompt: 'This page uses the legacy template. Propose a conversion to the pillar template that preserves the key messages from the current content.' },
      ...common,
    ];
  }
  if (templateId === 'pillar') {
    return [
      { label: 'Add a stat-grid after the intro', prompt: 'Add a stat-grid section after the intro split. Use placeholder numbers (e.g. 250 scholarships, $100M assets, 40 years, 500 funds) that I\'ll edit later.' },
      { label: 'Rewrite the intro split to be more emotional', prompt: 'Rewrite the first split section to lead with the human impact — why this matters to people, not just what we do.' },
      ...common,
    ];
  }
  if (templateId === 'program') {
    return [
      { label: 'Add a timeline to the main column', prompt: 'Add a timeline section inside the sidebar-layout main column. Use 5 milestones that describe a typical participant\'s year.' },
      { label: 'Add a testimonials section', prompt: 'Add a testimonials section with 2 placeholder quotes from past program participants.' },
      ...common,
    ];
  }
  if (templateId === 'landing') {
    return [
      { label: 'Add a pricing-tiers section', prompt: 'Add a pricing-tiers section for sponsorship levels: Community $2,500, Leadership $5,000 (featured), Legacy $10,000, Founders $25,000.' },
      { label: 'Add an FAQ section with 5 common questions', prompt: 'Add a faq-accordion section with 5 common questions a visitor might have about this event or campaign.' },
      ...common,
    ];
  }
  if (templateId === 'image-sections') {
    return [
      { label: 'Add a dual-panels section', prompt: 'Add a dual-panels section with two calls to action for different audiences.' },
      { label: 'Add an image-quote after the hero', prompt: 'Add an image-quote section after the hero with a placeholder quote about our community\'s impact.' },
      ...common,
    ];
  }
  return common;
}
---
<AdminLayout title={page.title}>
  <header class="admin-header">
    <div>
      <h1>{page.title}</h1>
      <p class="admin-sub"><code>{page.path}</code> · template: <span class="chip">{page.template}</span></p>
    </div>
    <div style="display:flex;gap:.5rem;">
      <a class="admin-btn admin-btn--ghost" href="/cpadmin">← All pages</a>
      <a class="admin-btn" href={page.path} target="_blank">View live ↗</a>
    </div>
  </header>

  <div class="editor-grid">
    <div class="editor-col">
      <form id="edit-form" data-slug={slug}>
        <section class="editor-card">
          <h2>Page meta</h2>
          <label>Title <input name="title" type="text" value={page.title} /></label>
          <label>Subtitle <input name="subtitle" type="text" value={page.subtitle ?? ''} /></label>
          <label>Template
            <select name="template">
              {TEMPLATES.map((t) => (
                <option value={t.id} selected={page.template === t.id}>{t.label}</option>
              ))}
            </select>
          </label>
          {template && (
            <p class="hint">
              {template.description}
            </p>
          )}
        </section>

        <section class="editor-card">
          <h2>Sections (JSON)</h2>
          <p class="hint">
            JSON array of sections. Each section has a <code>kind</code> plus fields for that type.
            Preferred for this template: {preferredKinds.length > 0 ? preferredKinds.join(', ') : '—'}.
            Always available: {UNIVERSAL_SECTIONS.join(', ')}. Other kinds ({otherKinds.length}): use when they fit better.
          </p>
          <textarea name="sections" rows="22" spellcheck="false" set:text={JSON.stringify(page.sections, null, 2)} />
        </section>

        <section class="editor-card">
          <h2>Legacy HTML body</h2>
          <p class="hint">Raw WordPress HTML. Only rendered when template = <code>legacy</code>.</p>
          <textarea name="legacyBody" rows="12" spellcheck="false" set:text={page.legacyBody} />
        </section>

        <div class="editor-actions">
          <button type="submit" class="admin-btn">Save</button>
          <span id="save-status" class="admin-dim"></span>
        </div>
      </form>
    </div>

    <aside class="editor-col editor-col--aside">
      <section class="editor-card">
        <h2>Preview</h2>
        <p class="hint">Live from D1 (no build needed). Refreshes on save.</p>
        <iframe id="preview" src={`/cpadmin/preview/${key}`} loading="lazy"></iframe>
        <div style="margin-top:.5rem;"><a class="admin-btn admin-btn--ghost" href={`/cpadmin/preview/${key}`} target="_blank">Open preview in new tab ↗</a></div>
      </section>

      <ChatPanel
        slug={slug}
        pageKey={key}
        template={page.template}
        title={page.title}
        sectionCount={sectionCount}
        suggestedPrompts={suggestedPrompts()}
      />

      <section class="editor-card">
        <h2>Version history</h2>
        {versions.length === 0 && <p class="admin-dim">No edits yet.</p>}
        <ul class="version-list">
          {versions.map((v) => (
            <li>
              <div>
                <strong>{fmtDate(v.createdAt)}</strong>
                <span class="chip chip--muted" style="margin-left:.5rem;">{v.author ?? 'unknown'}</span>
              </div>
              <button class="admin-btn admin-btn--ghost" type="button" data-revert={v.id}>Revert to this</button>
            </li>
          ))}
        </ul>
      </section>
    </aside>
  </div>

  <style>
    .editor-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 1024px) {
      .editor-grid { grid-template-columns: minmax(0,1.3fr) minmax(0,1fr); }
    }
    .editor-col { display: flex; flex-direction: column; gap: 1.25rem; }
    .editor-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem 1.25rem 1.25rem;
    }
    .editor-card h2 {
      margin: 0 0 .85rem;
      font-size: .8rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--text-dim);
    }
    .editor-card label {
      display: block;
      margin-bottom: .85rem;
      font-size: .85rem;
      color: var(--text-dim);
    }
    .editor-card input[type="text"],
    .editor-card select,
    .editor-card textarea {
      display: block;
      width: 100%;
      margin-top: .3rem;
      padding: .55rem .7rem;
      background: var(--panel-2);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: .9rem;
      border-radius: 6px;
      font-family: inherit;
      box-sizing: border-box;
    }
    .editor-card textarea {
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: .8rem;
      line-height: 1.5;
      resize: vertical;
    }
    .editor-card .hint {
      color: var(--text-muted);
      font-size: .75rem;
      margin: 0 0 .6rem;
    }
    .editor-actions {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-top: 1rem;
    }
    #preview {
      display: block;
      width: 100%;
      height: 720px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: white;
    }
    .version-list { list-style: none; padding: 0; margin: 0; max-height: 320px; overflow-y: auto; }
    .version-list li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: .75rem;
      padding: .6rem 0;
      border-bottom: 1px solid var(--border);
    }
    .version-list li:last-child { border-bottom: none; }
  </style>

  <script>
    const form = document.getElementById('edit-form') as HTMLFormElement;
    const slug = form.dataset.slug ?? '';
    const status = document.getElementById('save-status') as HTMLSpanElement;
    const preview = document.getElementById('preview') as HTMLIFrameElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const sectionsRaw = String(data.get('sections') ?? '[]');
      let sections: unknown[];
      try {
        sections = JSON.parse(sectionsRaw);
        if (!Array.isArray(sections)) throw new Error('sections must be an array');
      } catch (err) {
        status.textContent = `Invalid JSON: ${(err as Error).message}`;
        status.style.color = 'var(--danger)';
        return;
      }

      status.textContent = 'Saving...';
      status.style.color = 'var(--text-dim)';

      const body = {
        title: String(data.get('title') ?? ''),
        subtitle: String(data.get('subtitle') ?? '') || null,
        template: String(data.get('template') ?? 'legacy'),
        sections,
        legacyBody: String(data.get('legacyBody') ?? ''),
      };

      const slugPath = slug.split('/').map(encodeURIComponent).join('/');
      const res = await fetch(`/api/pages/${slugPath}`, {
        method: 'PUT',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      const payload = await res.json().catch(() => ({}));
      if (!res.ok) {
        status.textContent = `Save failed: ${(payload as { error?: string }).error ?? res.status}`;
        status.style.color = 'var(--danger)';
        return;
      }
      status.textContent = 'Saved. Reloading preview...';
      status.style.color = 'var(--success)';
      // Bust preview cache
      preview.src = preview.src.split('?')[0] + '?v=' + Date.now();
      // Soft-reload this page so version history updates
      setTimeout(() => { window.location.reload(); }, 600);
    });

    document.querySelectorAll('[data-revert]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = Number((btn as HTMLElement).dataset.revert);
        if (!confirm(`Revert to version ${id}? This creates a new version entry.`)) return;
        const revertPath = slug.split('/').map(encodeURIComponent).join('/');
        const res = await fetch(`/api/pages/${revertPath}/revert`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ versionId: id }),
        });
        if (!res.ok) {
          const payload = await res.json().catch(() => ({}));
          alert(`Revert failed: ${(payload as { error?: string }).error ?? res.status}`);
          return;
        }
        window.location.reload();
      });
    });
  </script>
</AdminLayout>
