---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ContentRenderer from '../../../components/ContentRenderer.astro';
import PageCTA from '../../../components/PageCTA.astro';
import { getDB, getPage } from '../../../lib/d1';
import { extractLead } from '../../../lib/content-parser';

export const prerender = false;

const key = Astro.params.key ?? '';
const slug = key === '__home__' ? '' : key;
const db = getDB(Astro.locals);
const page = await getPage(db, slug);
if (!page) {
  return new Response('page not found', { status: 404 });
}

const path = page.path || '/';
const usePolishedRenderer =
  !path.startsWith('/story') &&
  !path.startsWith('/about/news') &&
  !path.startsWith('/about/events-calendar') &&
  path !== '/search';
const leadText = usePolishedRenderer ? extractLead(page.legacyBody || '') : null;
---
<Layout title={page.title}>
  <div style="background:#fff3cd;border-bottom:1px solid #e6c96a;padding:.5rem 1rem;font-size:.85rem;color:#856404;font-family:system-ui;">
    <strong>Preview:</strong> this is a live view from D1 (not the published site). Close this tab or return to the editor when done.
  </div>
  <div class="page-banner">
    <div class="container">
      <h1 class="page-banner__title">{page.title}</h1>
      {page.subtitle
        ? <p class="page-banner__subtitle">{page.subtitle}</p>
        : leadText && <p class="page-banner__subtitle">{leadText}</p>}
    </div>
  </div>

  <Breadcrumb />

  {usePolishedRenderer ? (
    <>
      <ContentRenderer html={page.legacyBody || ''} hoistLead={!!leadText} />
      <PageCTA path={path} />
    </>
  ) : (
    <div class="page-content">
      <div class="container">
        <div class="article-body prose">
          <Fragment set:html={page.legacyBody || ''} />
        </div>
      </div>
    </div>
  )}
</Layout>
