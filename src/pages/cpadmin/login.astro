---
export const prerender = false;

const errorParam = Astro.url.searchParams.get('error');
const errorMessage = errorParam === '1' ? 'Invalid password.' : null;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>cpadmin login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <style>
    body {
      font-family: -apple-system, system-ui, sans-serif;
      background: #0b1220;
      color: #e8eefb;
      min-height: 100vh;
      display: grid;
      place-items: center;
      margin: 0;
    }
    .card {
      background: #121a2e;
      padding: 2rem 2.25rem;
      border-radius: 12px;
      width: min(380px, 92vw);
      box-shadow: 0 24px 48px rgba(0,0,0,.4);
      border: 1px solid #1f2a46;
    }
    h1 { margin: 0 0 1.25rem; font-size: 1.1rem; letter-spacing: .06em; text-transform: uppercase; color: #9fb0d8; }
    label { display: block; font-size: .85rem; color: #9fb0d8; margin-bottom: .35rem; }
    input[type="password"] {
      width: 100%;
      padding: .7rem .85rem;
      border-radius: 8px;
      border: 1px solid #2a3a63;
      background: #0d1526;
      color: #e8eefb;
      font-size: 1rem;
      box-sizing: border-box;
    }
    input[type="password"]:focus { outline: 2px solid #4287f5; outline-offset: 1px; }
    button {
      margin-top: 1rem;
      width: 100%;
      padding: .7rem;
      border-radius: 8px;
      border: none;
      background: #3b7dff;
      color: white;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
    }
    button:hover { background: #2d68de; }
    .err { color: #ff8080; font-size: .85rem; margin-top: .75rem; }
    .hint { color: #6b7ea3; font-size: .75rem; margin-top: 1.25rem; line-height: 1.5; }
  </style>
</head>
<body>
  <form class="card" method="post" action="/api/login">
    <h1>Content admin</h1>
    <label for="password">Password</label>
    <input id="password" name="password" type="password" autocomplete="current-password" required autofocus />
    <button type="submit">Sign in</button>
    {errorMessage && <p class="err">{errorMessage}</p>}
    <p class="hint">Access is restricted to THCF content editors.</p>
  </form>
</body>
</html>
