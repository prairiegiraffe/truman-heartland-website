---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ContentRenderer from "../components/ContentRenderer.astro";
import PageCTA from "../components/PageCTA.astro";
import allPages from "../data/pages.json";

export function getStaticPaths() {
  const skipPaths = new Set([
    "/",
    "/news",
  ]);

  const skipPrefixes = ["/cpadmin"];

  return allPages
    .filter((page: any) => {
      if (skipPaths.has(page.path)) return false;
      if (skipPrefixes.some((prefix) => page.path.startsWith(prefix))) return false;
      return true;
    })
    .map((page: any) => {
      const slug = page.path.replace(/^\//, "").split("/");
      return {
        params: { slug: slug.join("/") || undefined },
        props: { page },
      };
    });
}

const { page } = Astro.props;

const path: string = page.path || "";
const usePolishedRenderer =
  !path.startsWith("/story") &&
  !path.startsWith("/about/news") &&
  !path.startsWith("/about/events-calendar") &&
  path !== "/search";
---

<Layout title={page.title}>
  <div class="page-banner">
    <div class="container">
      <h1 class="page-banner__title">{page.title}</h1>
    </div>
  </div>

  <Breadcrumb />

  {usePolishedRenderer ? (
    <>
      <ContentRenderer html={page.body} />
      <PageCTA path={path} />
    </>
  ) : (
    <div class="page-content">
      <div class="container">
        <div class="article-body prose">
          <Fragment set:html={page.body} />
        </div>
      </div>
    </div>
  )}
</Layout>
