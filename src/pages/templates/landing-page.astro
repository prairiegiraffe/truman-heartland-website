---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import StatCounter from "../../components/StatCounter.astro";
---

<Layout title="Template: Landing Page" description="A campaign-style landing page with hero, stats, image gallery, and multiple CTA sections.">

  <!-- Full-Width Hero -->
  <section class="landing-hero">
    <div class="landing-hero__bg">
      <img src="https://stdidthcfprod.blob.core.windows.net/thcf/images/Home/_square/Home_CommunityGrants.png" alt="" loading="eager" />
    </div>
    <div class="landing-hero__overlay"></div>
    <div class="container landing-hero__content">
      <span class="landing-hero__badge reveal">Now Open</span>
      <h1 class="landing-hero__title reveal">Toast to Our Towns Gala 2025</h1>
      <p class="landing-hero__subtitle reveal">Join us for an unforgettable evening celebrating the communities that make Eastern Jackson County extraordinary.</p>
      <div class="landing-hero__actions reveal">
        <a href="/gala" class="btn btn-primary btn-lg">Reserve Your Table</a>
        <a href="/gala" class="btn btn-outline-white btn-lg">View Sponsorship Levels</a>
      </div>
    </div>
  </section>

  <!-- Quick Stats -->
  <section class="section section--navy">
    <div class="container">
      <div class="home-stats__grid reveal-stagger">
        <StatCounter target={800} suffix="+" label="Guests Annually" />
        <StatCounter target={150} prefix="$" suffix="K" label="Raised in 2024" />
        <StatCounter target={25} suffix="" label="Community Awards Given" />
        <StatCounter target={12} suffix="" label="Years Running" />
      </div>
    </div>
  </section>

  <!-- What to Expect — Alternating Image/Text -->
  <section class="section section--white">
    <div class="container">
      <SectionHeader
        eyebrow="The Experience"
        title="An Evening to Remember"
        body="From cocktails to community awards, every moment of the gala is designed to celebrate and uplift the people and organizations of Eastern Jackson County."
        center={true}
        accent={true}
      />

      <!-- Feature 1 -->
      <div class="section__split" style="margin-bottom: var(--space-3xl);">
        <div class="section__split-image reveal--left">
          <img src="https://stdidthcfprod.blob.core.windows.net/thcf/images/News/2025-Jan/_wide/Screenshot-2025-01-08-at-2.03.16-AM.png" alt="Gala dinner" loading="lazy" />
        </div>
        <div class="section__split-text reveal--right">
          <p class="section__eyebrow">6:00 PM</p>
          <h3 class="section__title" style="color: var(--color-navy);">Cocktails & Silent Auction</h3>
          <p class="section__body">Mingle with community leaders, browse curated auction items from local businesses, and enjoy signature cocktails as the evening begins.</p>
        </div>
      </div>

      <!-- Feature 2 (reversed) -->
      <div class="section__split" style="margin-bottom: var(--space-3xl);">
        <div class="section__split-text reveal--left" style="order: 0;">
          <p class="section__eyebrow">7:30 PM</p>
          <h3 class="section__title" style="color: var(--color-navy);">Dinner & Awards Ceremony</h3>
          <p class="section__body">A plated dinner followed by the Heartland Awards ceremony, honoring outstanding individuals and organizations making a difference in our region.</p>
        </div>
        <div class="section__split-image reveal--right" style="order: 1;">
          <img src="https://stdidthcfprod.blob.core.windows.net/thcf/images/Home/_square/Scholarship-Program.png" alt="Awards ceremony" loading="lazy" />
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="section__split">
        <div class="section__split-image reveal--left">
          <img src="https://stdidthcfprod.blob.core.windows.net/thcf/images/Home/_square/Home_CommunityGrants.png" alt="Live music" loading="lazy" />
        </div>
        <div class="section__split-text reveal--right">
          <p class="section__eyebrow">9:00 PM</p>
          <h3 class="section__title" style="color: var(--color-navy);">Live Music & Dancing</h3>
          <p class="section__body">Close out the evening with live entertainment, dancing, and dessert. It's a celebration — and you're the guest of honor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsorship Tiers -->
  <section class="section section--light">
    <div class="container">
      <SectionHeader
        eyebrow="Sponsorships"
        title="Make Your Mark on the Gala"
        body="Your sponsorship directly supports THCF's community grantmaking and scholarship programs. Choose the level that's right for you."
        center={true}
        accent={true}
      />

      <div class="pricing-grid reveal-stagger">
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>Bronze</h3>
            <div class="pricing-card__price">$1,000</div>
          </div>
          <ul class="pricing-card__features">
            <li>2 gala tickets</li>
            <li>Name in event program</li>
            <li>Social media recognition</li>
            <li>Tax-deductible contribution</li>
          </ul>
          <a href="/about/contact-us" class="btn btn-outline" style="width: 100%; text-align: center;">Select</a>
        </div>

        <div class="pricing-card pricing-card--featured">
          <div class="pricing-card__badge">Most Popular</div>
          <div class="pricing-card__header">
            <h3>Silver</h3>
            <div class="pricing-card__price">$2,500</div>
          </div>
          <ul class="pricing-card__features">
            <li>4 gala tickets</li>
            <li>Logo in event program</li>
            <li>Social media spotlight</li>
            <li>Recognition from stage</li>
            <li>Premium table placement</li>
          </ul>
          <a href="/about/contact-us" class="btn btn-primary" style="width: 100%; text-align: center;">Select</a>
        </div>

        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>Gold</h3>
            <div class="pricing-card__price">$5,000</div>
          </div>
          <ul class="pricing-card__features">
            <li>8 gala tickets (full table)</li>
            <li>Full-page program ad</li>
            <li>Video spotlight package</li>
            <li>VIP reception access</li>
            <li>Named award presenter</li>
          </ul>
          <a href="/about/contact-us" class="btn btn-outline" style="width: 100%; text-align: center;">Select</a>
        </div>

        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>Platinum</h3>
            <div class="pricing-card__price">$10,000</div>
          </div>
          <ul class="pricing-card__features">
            <li>16 gala tickets (two tables)</li>
            <li>Title sponsor recognition</li>
            <li>Branded photo backdrop</li>
            <li>Keynote introduction</li>
            <li>Year-round THCF partnership</li>
            <li>Custom promotional video</li>
          </ul>
          <a href="/about/contact-us" class="btn btn-outline" style="width: 100%; text-align: center;">Select</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section section--navy-dark">
    <div class="container">
      <div class="story-spotlight reveal">
        <div class="story-spotlight__image">
          <img src="https://stdidthcfprod.blob.core.windows.net/thcf/images/Home/_square/Scholarship-Program.png" alt="Gala attendees" loading="lazy" />
        </div>
        <div class="story-spotlight__content">
          <p class="section__eyebrow" style="color: var(--color-green-light);">From a Past Attendee</p>
          <blockquote class="story-spotlight__quote">
            "The Toast to Our Towns Gala is more than just a party — it's a reminder of everything our community can accomplish when we come together. We leave inspired every single year."
          </blockquote>
          <p class="story-spotlight__attribution">— David & Sarah K., Gala Sponsors since 2018</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Event Details -->
  <section class="section section--white">
    <div class="container">
      <SectionHeader
        eyebrow="Details"
        title="Event Information"
        center={true}
        accent={true}
      />
      <div class="details-grid reveal-stagger">
        <div class="details-card">
          <div class="details-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>Date</h3>
          <p>Saturday, October 18, 2025</p>
          <p class="details-card__sub">Doors open at 5:30 PM</p>
        </div>
        <div class="details-card">
          <div class="details-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Venue</h3>
          <p>The Grand Ballroom</p>
          <p class="details-card__sub">500 Main Street, Independence, MO</p>
        </div>
        <div class="details-card">
          <div class="details-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3>Dress Code</h3>
          <p>Semi-Formal / Cocktail</p>
          <p class="details-card__sub">Celebrate in style</p>
        </div>
        <div class="details-card">
          <div class="details-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3>Tickets</h3>
          <p>$150 per person</p>
          <p class="details-card__sub">Tables of 8 available</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="section section--blue-light">
    <div class="container" style="max-width: 800px;">
      <SectionHeader
        eyebrow="FAQs"
        title="Frequently Asked Questions"
        center={true}
        accent={true}
      />
      <div class="faq-list reveal-stagger">
        <details class="faq-item">
          <summary class="faq-item__question">Is there parking available at the venue?</summary>
          <div class="faq-item__answer">
            <p>Yes, complimentary parking is available in the attached garage. Valet parking is also available for $15. We encourage carpooling when possible.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-item__question">Can I purchase a single ticket or do I need a full table?</summary>
          <div class="faq-item__answer">
            <p>Both options are available! Individual tickets are $150 each, and full tables of 8 are $1,100 (a savings of $100). We'll seat individual ticket holders together so everyone has a great time.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-item__question">Are there dietary accommodations?</summary>
          <div class="faq-item__answer">
            <p>Absolutely. We offer vegetarian, vegan, and gluten-free options. Please indicate any dietary needs when you RSVP, and our catering team will ensure you're taken care of.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-item__question">How do I nominate someone for a Heartland Award?</summary>
          <div class="faq-item__answer">
            <p>Nominations open each spring. Visit our Awards page or contact our events team to submit a nomination. We welcome nominations from community members, nonprofit leaders, and past honorees.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-item__question">Is my sponsorship tax-deductible?</summary>
          <div class="faq-item__answer">
            <p>A portion of your sponsorship is tax-deductible. THCF will provide a written acknowledgment letter detailing the tax-deductible amount after the event. Please consult your tax advisor for specifics.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="home-cta-band">
    <div class="container">
      <div class="home-cta-band__inner reveal">
        <div class="home-cta-band__text">
          <h2>Don't Miss the Best Night of the Year</h2>
          <p>Tables are filling up fast. Secure your spot at the 2025 Toast to Our Towns Gala today.</p>
        </div>
        <a href="/gala" class="btn btn-primary btn-lg">Get Your Tickets</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Landing Hero */
  .landing-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .landing-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .landing-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .landing-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,31,63,0.9) 0%, rgba(0,31,63,0.6) 100%);
    z-index: 1;
  }

  .landing-hero__content {
    position: relative;
    z-index: 2;
    padding: var(--space-3xl) 0;
    max-width: 700px;
    color: white;
  }

  .landing-hero__badge {
    display: inline-block;
    background: var(--color-green);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: 4px;
    margin-bottom: var(--space-md);
  }

  .landing-hero__title {
    font-size: clamp(2.5rem, 6vw, var(--text-6xl));
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .landing-hero__subtitle {
    font-size: var(--text-lg);
    opacity: 0.9;
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-xl);
  }

  .landing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Pricing Grid */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  @media (min-width: 640px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .pricing-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 12px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .pricing-card--featured {
    border-color: var(--color-green);
    border-width: 2px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
  }

  .pricing-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-green);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: 20px;
    white-space: nowrap;
  }

  .pricing-card__header {
    text-align: center;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-gray-100);
    margin-bottom: var(--space-md);
  }

  .pricing-card__header h3 {
    font-size: var(--text-lg);
    color: var(--color-navy);
    margin-bottom: var(--space-xs);
  }

  .pricing-card__price {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-green);
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg) 0;
    flex: 1;
  }

  .pricing-card__features li {
    padding: var(--space-xs) 0;
    font-size: var(--text-sm);
    color: var(--color-text);
    border-bottom: 1px solid var(--color-gray-50);
    padding-left: var(--space-md);
    position: relative;
  }

  .pricing-card__features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-green);
    font-weight: 700;
  }

  /* Details Grid */
  .details-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .details-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .details-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .details-card {
    text-align: center;
    padding: var(--space-xl);
  }

  .details-card__icon {
    color: var(--color-green);
    margin-bottom: var(--space-md);
  }

  .details-card h3 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    margin-bottom: var(--space-xs);
  }

  .details-card p {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-navy);
    margin: 0;
  }

  .details-card__sub {
    font-size: var(--text-sm) !important;
    font-weight: 400 !important;
    color: var(--color-text-light) !important;
    margin-top: var(--space-2xs) !important;
  }

  /* FAQ Accordion */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .faq-item {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-item__question {
    padding: var(--space-md) var(--space-lg);
    font-weight: 600;
    color: var(--color-navy);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.2s ease;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__question::after {
    content: '+';
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-green);
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-left: var(--space-md);
  }

  .faq-item[open] .faq-item__question::after {
    content: '−';
  }

  .faq-item__question:hover {
    background: var(--color-gray-50);
  }

  .faq-item__answer {
    padding: 0 var(--space-lg) var(--space-md);
  }

  .faq-item__answer p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    margin: 0;
  }
</style>
