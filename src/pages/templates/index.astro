---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export const prerender = true;
---

<Layout title="Page Templates" description="Browse our collection of page templates to see how content can be styled with different sections, layouts, and visual treatments.">

  <div class="page-banner">
    <div class="container">
      <p class="page-banner__category">Design System</p>
      <h1 class="page-banner__title">Page Templates</h1>
    </div>
  </div>

  <Breadcrumb />

  <section class="section section--white">
    <div class="container">
      <div style="max-width: 680px; margin-bottom: var(--space-2xl);">
        <p style="font-size: var(--text-lg); color: var(--color-text-light); line-height: var(--leading-relaxed);">These templates demonstrate how pages can be designed with varied sections, color treatments, and layout patterns — no giant blocks of text required. Each template is fully reusable and can be adapted for any content.</p>
      </div>

      <div class="template-grid reveal-stagger">

        <a href="/templates/pillar-page" class="template-card card-lift">
          <div class="template-card__preview template-card__preview--pillar">
            <div class="template-card__mock">
              <div class="mock-banner"></div>
              <div class="mock-split"><div></div><div></div></div>
              <div class="mock-stats"></div>
              <div class="mock-cards"><div></div><div></div><div></div></div>
              <div class="mock-split"><div></div><div></div></div>
              <div class="mock-cta"></div>
            </div>
          </div>
          <div class="template-card__content">
            <span class="chip" style="background: var(--color-navy); color: white;">Pillar Page</span>
            <h2 class="template-card__title">Content-Rich Pillar Page</h2>
            <p class="template-card__body">Alternating sections with split layouts, stat counters, icon cards, testimonial spotlight, and a CTA band. Great for overview pages like "Charitable Giving" or "About Us."</p>
            <span class="template-card__link">View Template &rarr;</span>
          </div>
        </a>

        <a href="/templates/program-page" class="template-card card-lift">
          <div class="template-card__preview template-card__preview--program">
            <div class="template-card__mock">
              <div class="mock-banner"></div>
              <div class="mock-sidebar-layout">
                <div class="mock-sidebar"><div></div><div></div></div>
                <div class="mock-content"><div></div><div></div><div></div><div></div></div>
              </div>
            </div>
          </div>
          <div class="template-card__content">
            <span class="chip" style="background: var(--color-green); color: white;">Program Page</span>
            <h2 class="template-card__title">Program Page with Sidebar</h2>
            <p class="template-card__body">Sticky sidebar with quick facts, section navigation, and contact card alongside rich content: timelines, numbered steps, testimonials, and feature grids.</p>
            <span class="template-card__link">View Template &rarr;</span>
          </div>
        </a>

        <a href="/templates/landing-page" class="template-card card-lift">
          <div class="template-card__preview template-card__preview--landing">
            <div class="template-card__mock">
              <div class="mock-hero"></div>
              <div class="mock-stats"></div>
              <div class="mock-split"><div></div><div></div></div>
              <div class="mock-pricing"><div></div><div class="featured"></div><div></div><div></div></div>
              <div class="mock-faq"><div></div><div></div><div></div></div>
            </div>
          </div>
          <div class="template-card__content">
            <span class="chip" style="background: var(--color-blue-100); color: var(--color-navy);">Landing Page</span>
            <h2 class="template-card__title">Campaign Landing Page</h2>
            <p class="template-card__body">Full-width hero, animated stats, alternating features, pricing/sponsorship tiers, FAQ accordion, and event details. Perfect for galas, campaigns, and fundraisers.</p>
            <span class="template-card__link">View Template &rarr;</span>
          </div>
        </a>

        <a href="/templates/image-sections" class="template-card card-lift">
          <div class="template-card__preview template-card__preview--images">
            <div class="template-card__mock">
              <div class="mock-banner"></div>
              <div class="mock-img-full"></div>
              <div class="mock-img-split"><div></div><div></div></div>
              <div class="mock-img-full mock-img-full--green"></div>
              <div class="mock-img-dual"><div></div><div></div></div>
              <div class="mock-img-mosaic"><div></div><div></div><div></div></div>
            </div>
          </div>
          <div class="template-card__content">
            <span class="chip" style="background: var(--color-green-dark); color: white;">Image Sections</span>
            <h2 class="template-card__title">Image Background Sections</h2>
            <p class="template-card__body">8 patterns: dark overlays, brand-colored overlays, parallax, split panels, floating cards, image-to-solid fades, quote blocks, and hover mosaics.</p>
            <span class="template-card__link">View Template &rarr;</span>
          </div>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style>
  .template-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .template-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .template-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .template-card {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .template-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .template-card__preview {
    padding: var(--space-lg);
    background: var(--color-gray-50);
    border-bottom: 1px solid var(--color-gray-200);
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .template-card__mock {
    width: 100%;
    max-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  /* Mock page elements */
  .mock-banner {
    height: 20px;
    background: var(--color-navy);
    border-radius: 2px;
  }

  .mock-hero {
    height: 40px;
    background: linear-gradient(135deg, var(--color-navy), var(--color-navy-50));
    border-radius: 2px;
  }

  .mock-stats {
    height: 16px;
    background: var(--color-navy);
    border-radius: 2px;
  }

  .mock-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    height: 24px;
  }

  .mock-split > div {
    background: var(--color-gray-200);
    border-radius: 2px;
  }

  .mock-split > div:first-child {
    background: var(--color-blue-100);
  }

  .mock-cards {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3px;
    height: 20px;
  }

  .mock-cards > div {
    background: var(--color-gray-200);
    border-radius: 2px;
  }

  .mock-cta {
    height: 14px;
    background: var(--color-green);
    border-radius: 2px;
  }

  .mock-sidebar-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4px;
    height: 80px;
  }

  .mock-sidebar {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mock-sidebar > div {
    flex: 1;
    background: var(--color-blue-100);
    border-radius: 2px;
  }

  .mock-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mock-content > div {
    flex: 1;
    background: var(--color-gray-200);
    border-radius: 2px;
  }

  .mock-pricing {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
    height: 28px;
  }

  .mock-pricing > div {
    background: var(--color-gray-200);
    border-radius: 2px;
  }

  .mock-pricing > .featured {
    background: var(--color-green);
    border: 1px solid var(--color-green);
  }

  .mock-faq {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .mock-faq > div {
    height: 8px;
    background: var(--color-blue-50);
    border-radius: 2px;
  }

  .mock-img-full {
    height: 24px;
    background: linear-gradient(135deg, var(--color-navy-dark), var(--color-navy));
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .mock-img-full::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 40%;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.15));
  }

  .mock-img-full--green {
    background: linear-gradient(135deg, var(--color-green-dark), var(--color-green));
  }

  .mock-img-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    height: 24px;
  }

  .mock-img-split > div:first-child {
    background: var(--color-navy);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .mock-img-split > div:first-child::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(255,255,255,0.2));
  }

  .mock-img-split > div:last-child {
    background: var(--color-gray-100);
    border-radius: 2px;
  }

  .mock-img-dual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    height: 20px;
  }

  .mock-img-dual > div {
    background: var(--color-navy);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .mock-img-dual > div::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.1);
  }

  .mock-img-mosaic {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2px;
    height: 16px;
  }

  .mock-img-mosaic > div {
    background: var(--color-gray-300);
    border-radius: 2px;
  }

  .mock-img-mosaic > div:first-child {
    background: var(--color-navy-light);
  }

  .template-card__content {
    padding: var(--space-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .template-card__title {
    font-size: var(--text-lg);
    color: var(--color-navy);
    margin: var(--space-sm) 0 var(--space-xs);
  }

  .template-card__body {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .template-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-green);
    margin-top: var(--space-md);
  }
</style>
