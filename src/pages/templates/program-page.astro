---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SectionHeader from "../../components/SectionHeader.astro";

export const prerender = true;
---

<Layout title="Template: Program Page with Sidebar" description="A program or service page demonstrating sidebar navigation, quick-info cards, and content sections with a two-column layout.">

  <!-- Page Banner -->
  <div class="page-banner">
    <div class="container">
      <p class="page-banner__category">Template Example</p>
      <h1 class="page-banner__title">Youth Advisory Council</h1>
      <p class="page-banner__subtitle">Empowering the next generation of philanthropists in Eastern Jackson County</p>
    </div>
  </div>

  <Breadcrumb />

  <!-- Main Content with Sidebar -->
  <section class="section section--white">
    <div class="container">
      <div class="content-with-sidebar">

        <!-- Sidebar -->
        <aside class="content-sidebar reveal--left">
          <!-- Quick Info Card -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">Quick Facts</h3>
            <ul class="sidebar-card__list">
              <li>
                <span class="sidebar-card__label">Ages</span>
                <span class="sidebar-card__value">14–18</span>
              </li>
              <li>
                <span class="sidebar-card__label">Meets</span>
                <span class="sidebar-card__value">Monthly</span>
              </li>
              <li>
                <span class="sidebar-card__label">Location</span>
                <span class="sidebar-card__value">THCF Offices</span>
              </li>
              <li>
                <span class="sidebar-card__label">Season</span>
                <span class="sidebar-card__value">Sept – May</span>
              </li>
              <li>
                <span class="sidebar-card__label">Cost</span>
                <span class="sidebar-card__value">Free</span>
              </li>
            </ul>
            <a href="/about/contact-us" class="btn btn-primary" style="width: 100%; text-align: center; margin-top: var(--space-md);">Apply Now</a>
          </div>

          <!-- Sidebar Nav -->
          <div class="sidebar-card">
            <h3 class="sidebar-card__title">In This Section</h3>
            <nav class="sidebar-nav">
              <a href="#overview" class="sidebar-nav__link is-active">Overview</a>
              <a href="#curriculum" class="sidebar-nav__link">Curriculum</a>
              <a href="#events" class="sidebar-nav__link">Events & Activities</a>
              <a href="#alumni" class="sidebar-nav__link">Alumni Spotlight</a>
              <a href="#apply" class="sidebar-nav__link">How to Apply</a>
            </nav>
          </div>

          <!-- Contact Card -->
          <div class="sidebar-card sidebar-card--green">
            <h3 class="sidebar-card__title" style="color: white;">Questions?</h3>
            <p style="color: rgba(255,255,255,0.9); font-size: var(--text-sm); margin-bottom: var(--space-md);">Reach out to our Youth Programs Coordinator.</p>
            <p style="color: white; font-weight: 600;">Jane Smith</p>
            <p><a href="mailto:jane@thcf.org" style="color: rgba(255,255,255,0.9);">jane@thcf.org</a></p>
            <p><a href="tel:+18168368189" style="color: rgba(255,255,255,0.9);">(816) 836-8189</a></p>
          </div>
        </aside>

        <!-- Main Content -->
        <div class="content-main reveal--right">

          <div id="overview" class="content-block">
            <h2>Program Overview</h2>
            <p>The Youth Advisory Council (YAC) is a student-led philanthropy program that empowers young people to make a real difference in their communities. Through hands-on grantmaking, community service, and leadership development, YAC members learn how philanthropy works — and why it matters.</p>
            <p>Each year, YAC members review grant applications from local nonprofits and award grants from a dedicated fund at THCF. Students gain experience in teamwork, decision-making, public speaking, and community engagement.</p>
          </div>

          <!-- Highlight Box -->
          <div class="highlight-box">
            <div class="highlight-box__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <strong>Now Accepting Applications!</strong>
              <p style="margin-top: var(--space-xs);">Applications for the 2025–2026 YAC cohort are open through June 30. No prior volunteer experience required.</p>
            </div>
          </div>

          <div id="curriculum" class="content-block">
            <h2>What Students Learn</h2>
            <p>The YAC curriculum is structured around four pillars of community engagement:</p>

            <div class="feature-grid">
              <div class="feature-grid__item">
                <div class="feature-grid__number">01</div>
                <h3>Philanthropy Foundations</h3>
                <p>Understanding the nonprofit ecosystem, community foundations, and how charitable dollars flow from donors to impact.</p>
              </div>
              <div class="feature-grid__item">
                <div class="feature-grid__number">02</div>
                <h3>Grantmaking Process</h3>
                <p>Reviewing real applications, conducting site visits, evaluating organizational capacity, and making funding decisions.</p>
              </div>
              <div class="feature-grid__item">
                <div class="feature-grid__number">03</div>
                <h3>Leadership Skills</h3>
                <p>Public speaking, group facilitation, critical thinking, and collaborative decision-making in a supportive environment.</p>
              </div>
              <div class="feature-grid__item">
                <div class="feature-grid__number">04</div>
                <h3>Community Service</h3>
                <p>Hands-on volunteer projects, community needs assessments, and understanding the challenges facing Eastern Jackson County.</p>
              </div>
            </div>
          </div>

          <div id="events" class="content-block">
            <h2>Events & Activities</h2>

            <!-- Timeline -->
            <div class="timeline">
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>September</h3>
                  <p>Kickoff retreat and team-building. Meet your cohort, set goals for the year, and begin orientation.</p>
                </div>
              </div>
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>October – November</h3>
                  <p>Philanthropy workshops and community needs assessment. Learn about the nonprofit landscape in EJC.</p>
                </div>
              </div>
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>December – January</h3>
                  <p>Grant application review period. Read proposals, discuss merits, and prepare for site visits.</p>
                </div>
              </div>
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>February</h3>
                  <p>Site visits to applicant organizations. See the work firsthand and ask questions.</p>
                </div>
              </div>
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>March</h3>
                  <p>Grant deliberation and final funding decisions. Present recommendations to the THCF board.</p>
                </div>
              </div>
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>April</h3>
                  <p>Annual YAC Fundraiser — plan, organize, and host a community event to raise funds for next year's grants.</p>
                </div>
              </div>
              <div class="timeline__item">
                <div class="timeline__marker"></div>
                <div class="timeline__content">
                  <h3>May</h3>
                  <p>Celebration event and certificate ceremony. Reflect on the year and welcome the incoming cohort.</p>
                </div>
              </div>
            </div>
          </div>

          <div id="alumni" class="content-block">
            <h2>Alumni Spotlight</h2>

            <!-- Testimonial Cards -->
            <div class="testimonial-grid">
              <div class="testimonial-card">
                <blockquote>"YAC taught me that even as a teenager, I had the power to shape my community. The grantmaking experience gave me skills I still use every day in my career."</blockquote>
                <div class="testimonial-card__author">
                  <div class="testimonial-card__avatar">AS</div>
                  <div>
                    <strong>Alex S.</strong>
                    <span>YAC Class of 2019</span>
                  </div>
                </div>
              </div>
              <div class="testimonial-card">
                <blockquote>"Being on YAC showed me what community foundations actually do. I went from not knowing what philanthropy meant to making real grants to real organizations."</blockquote>
                <div class="testimonial-card__author">
                  <div class="testimonial-card__avatar">MJ</div>
                  <div>
                    <strong>Maria J.</strong>
                    <span>YAC Class of 2021</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div id="apply" class="content-block">
            <h2>How to Apply</h2>
            <p>Joining YAC is easy. We welcome students from all backgrounds — no prior volunteer or philanthropy experience is needed.</p>

            <!-- Steps -->
            <div class="steps">
              <div class="steps__item">
                <div class="steps__number">1</div>
                <div>
                  <h3>Submit an Application</h3>
                  <p>Fill out our short online application form. You'll need a brief personal statement and one reference.</p>
                </div>
              </div>
              <div class="steps__item">
                <div class="steps__number">2</div>
                <div>
                  <h3>Interview</h3>
                  <p>Selected applicants will be invited for a casual 15-minute interview with our Youth Programs team.</p>
                </div>
              </div>
              <div class="steps__item">
                <div class="steps__number">3</div>
                <div>
                  <h3>Get Started</h3>
                  <p>Accepted students receive a welcome packet and attend the September kickoff retreat to begin their YAC journey.</p>
                </div>
              </div>
            </div>

            <div style="margin-top: var(--space-xl);">
              <a href="/about/contact-us" class="btn btn-primary">Start Your Application</a>
              <a href="/students/youth-advisory-council" class="btn btn-outline" style="margin-left: var(--space-sm);">Learn More About YAC</a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="home-cta-band">
    <div class="container">
      <div class="home-cta-band__inner reveal">
        <div class="home-cta-band__text">
          <h2>Know a Student Who'd Be Great for YAC?</h2>
          <p>Spread the word! Share our program with teachers, parents, and students in your community.</p>
        </div>
        <a href="/about/contact-us" class="btn btn-primary btn-lg">Nominate a Student</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Sidebar Layout */
  .content-with-sidebar {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 768px) {
    .content-with-sidebar {
      grid-template-columns: 280px 1fr;
    }
  }

  @media (min-width: 1024px) {
    .content-with-sidebar {
      grid-template-columns: 300px 1fr;
      gap: var(--space-3xl);
    }
  }

  .content-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .content-sidebar {
      position: sticky;
      top: calc(var(--space-xl) + 120px);
      align-self: start;
    }
  }

  /* Sidebar Cards */
  .sidebar-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  .sidebar-card--green {
    background: var(--color-green);
    border-color: var(--color-green);
  }

  .sidebar-card__title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-green);
  }

  .sidebar-card--green .sidebar-card__title {
    border-bottom-color: rgba(255,255,255,0.3);
  }

  .sidebar-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-card__list li {
    display: flex;
    justify-content: space-between;
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-gray-100);
    font-size: var(--text-sm);
  }

  .sidebar-card__list li:last-child {
    border-bottom: none;
  }

  .sidebar-card__label {
    color: var(--color-text-light);
  }

  .sidebar-card__value {
    font-weight: 600;
    color: var(--color-navy);
  }

  /* Sidebar Nav */
  .sidebar-nav {
    display: flex;
    flex-direction: column;
  }

  .sidebar-nav__link {
    display: block;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all 0.2s ease;
  }

  .sidebar-nav__link:hover,
  .sidebar-nav__link.is-active {
    color: var(--color-green);
    border-left-color: var(--color-green);
    background: var(--color-gray-50);
  }

  /* Content Main */
  .content-main {
    min-width: 0;
  }

  .content-block {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-gray-200);
  }

  .content-block:last-child {
    border-bottom: none;
  }

  .content-block h2 {
    font-size: var(--text-2xl);
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }

  .content-block p {
    color: var(--color-text);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-md);
  }

  /* Highlight Box */
  .highlight-box {
    display: flex;
    gap: var(--space-md);
    background: var(--color-blue-50);
    border-left: 4px solid var(--color-green);
    padding: var(--space-lg);
    border-radius: 0 8px 8px 0;
    margin-bottom: var(--space-2xl);
  }

  .highlight-box__icon {
    color: var(--color-green);
    flex-shrink: 0;
  }

  .highlight-box p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
  }

  /* Feature Grid */
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  @media (min-width: 640px) {
    .feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .feature-grid__item {
    padding: var(--space-lg);
    background: var(--color-gray-50);
    border-radius: 8px;
  }

  .feature-grid__number {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--color-green);
    opacity: 0.3;
    margin-bottom: var(--space-xs);
    line-height: 1;
  }

  .feature-grid__item h3 {
    font-size: var(--text-base);
    color: var(--color-navy);
    margin-bottom: var(--space-xs);
  }

  .feature-grid__item p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: var(--space-xl);
    margin-top: var(--space-lg);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: var(--color-gray-200);
  }

  .timeline__item {
    position: relative;
    padding-bottom: var(--space-lg);
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: calc(-1 * var(--space-xl) + 2px);
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-green);
    border: 2px solid var(--color-white);
    box-shadow: 0 0 0 2px var(--color-green);
  }

  .timeline__content h3 {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-2xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline__content p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
  }

  /* Testimonial Grid */
  .testimonial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  @media (min-width: 640px) {
    .testimonial-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .testimonial-card {
    background: var(--color-gray-50);
    border-radius: 8px;
    padding: var(--space-lg);
  }

  .testimonial-card blockquote {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-md) 0;
    padding: 0;
    border: none;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .testimonial-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-navy);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .testimonial-card__author strong {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-navy);
  }

  .testimonial-card__author span {
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  /* Steps */
  .steps {
    margin-top: var(--space-lg);
  }

  .steps__item {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-gray-100);
  }

  .steps__item:last-child {
    border-bottom: none;
  }

  .steps__number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-green);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-lg);
    font-weight: 700;
    flex-shrink: 0;
  }

  .steps__item h3 {
    font-size: var(--text-base);
    color: var(--color-navy);
    margin-bottom: var(--space-2xs);
  }

  .steps__item p {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
  }

  /* Banner subtitle */
  .page-banner__subtitle {
    font-size: var(--text-lg);
    opacity: 0.85;
    margin-top: var(--space-sm);
    max-width: 600px;
  }
</style>
